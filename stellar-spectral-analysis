# ==== EQUIVALENT WIDTH: LITHIUM ====
# EW = area between continuum (1.0) and the normalized line
# positive value = absorption, larger = stronger line = likely younger star
# specutils convention: EW is positive for absorption when continuum = 1.0

from specutils.analysis import equivalent_width

if wave_li is not None:
    # rebuild as Spectrum object — needs to be in specutils format
    li_spec = Spectrum(
        spectral_axis=wave_li * u.AA,
        flux=flux_li * u.dimensionless_unscaled
    )
    
    # integration window — ±3 Å around the Li line center
    # adjust width if the line looks broader/narrower 
    li_region = SpectralRegion((li_ref - 3) * u.AA, (li_ref + 3) * u.AA)
    
    ew_li = equivalent_width(li_spec, regions=li_region)
    print(f"\n--- Lithium EW ---")
    print(f"Li ref wavelength: {li_ref:.4f} Å")
    print(f"Li EW:             {ew_li:.4f}")
    print(f"Li EW (mÅ):        {ew_li.to(u.AA).value * 1000:.2f} mÅ")
else:
    print("Lithium region not covered — no EW calculated.")
