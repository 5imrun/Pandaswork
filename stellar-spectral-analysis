# ==== LOCAL CONTINUUM NORMALIZATION ====
spectrum = Spectrum(
    spectral_axis=xvals * u.AA,
    flux=yvals * u.Unit('erg / (cm^2 s AA)')
)

def local_normalize(spectrum, line_center, window=20, shoulder=5):
    lo = line_center - window
    hi = line_center + window
    region = SpectralRegion(lo * u.AA, hi * u.AA)
    try:
        sub = extract_region(spectrum, region)
    except Exception:
        print(f"Warning: {lo}-{hi} Å not covered, skipping.")
        return None, None
    wave = sub.spectral_axis.value
    flux = sub.flux.value
    shoulder_mask = (wave < line_center - shoulder) | (wave > line_center + shoulder)
    try:
        p_init = models.Chebyshev1D(1)
        fitter = fitting.LinearLSQFitter()
        p = fitter(p_init, wave[shoulder_mask], flux[shoulder_mask])
        continuum = p(wave)
        flux_norm = flux / continuum
    except Exception as e:
        print(f"Warning: continuum fit failed around {line_center} Å: {e}")
        return None, None
    return wave, flux_norm

def centroid(wave, flux_norm, line_center, half_width=3):
    mask = (wave > line_center - half_width) & (wave < line_center + half_width)
    w = wave[mask]
    f = flux_norm[mask]
    deficit = 1.0 - f
    deficit = np.clip(deficit, 0, None)
    if deficit.sum() == 0:
        return None
    return np.sum(w * deficit) / np.sum(deficit)


# ==== PER-STAR RV CORRECTION ====
# Simple Doppler formula: λ_obs = λ_rest × (1 + v/c)
# Rearranged: v/c = (λ_obs - λ_rest) / λ_rest
# Apply same ratio to every other line: λ_corrected = λ_rest × (1 + v/c)
#
# For young/active stars H-alpha can be in emission, which breaks the
# absorption centroid. Fall back to Na D1, always in absorption.

HA_REST = 6562.801  # H-alpha rest wavelength in air (Å)
NA_REST = 5889.95   # Na D1 rest wavelength in air (Å)

# normalize around H-alpha at rest to check absorption vs emission
wave_ha_init, flux_ha_init = local_normalize(spectrum, line_center=HA_REST, window=40, shoulder=8)

if wave_ha_init is None:
    raise RuntimeError("H-alpha not covered — cannot compute RV correction.")

# if peak above 1.0 is bigger than dip below 1.0, line is in emission
ha_is_emission = (flux_ha_init.max() - 1.0) > (1.0 - flux_ha_init.min())

if ha_is_emission:
    print("H-alpha is in EMISSION (active/young star) — using Na D1 for RV correction.")
    wave_rv, flux_rv = local_normalize(spectrum, line_center=NA_REST, window=20, shoulder=6)
    rv_rest = NA_REST
    if wave_rv is None:
        raise RuntimeError("Na D1 also not covered — cannot compute RV correction.")
else:
    wave_rv, flux_rv = wave_ha_init, flux_ha_init
    rv_rest = HA_REST

c_rv = centroid(wave_rv, flux_rv, rv_rest)
if c_rv is None:
    raise RuntimeError("RV centroid failed — line too noisy.")

# v/c ratio — apply directly to all rest wavelengths
v_over_c      = (c_rv - rv_rest) / rv_rest
velocity_km_s = v_over_c * const.c.to('km/s').value

print(f"\n--- RV Correction ---")
print(f"Reference line:    {'Na D1' if ha_is_emission else 'H-alpha'}")
print(f"Rest wavelength:   {rv_rest:.4f} Å")
print(f"Observed centroid: {c_rv:.4f} Å")
print(f"Radial velocity:   {velocity_km_s:.2f} km/s")

# λ_obs = λ_rest × (1 + v/c) for every line
ha_ref   = 6562.801 * (1 + v_over_c)
li_ref   = 6707.76  * (1 + v_over_c)
fe_ref   = 6707.4   * (1 + v_over_c)
cahk_h   = 3968.0   * (1 + v_over_c)
cahk_k   = 3933.0   * (1 + v_over_c)
na_ref   = 5889.95  * (1 + v_over_c)
mg_ref   = 5183.62  * (1 + v_over_c)


# normalize around each feature using corrected centers
wave_ha,   flux_ha   = local_normalize(spectrum, line_center=ha_ref,  window=40, shoulder=8)
wave_li,   flux_li   = local_normalize(spectrum, line_center=li_ref,  window=15, shoulder=4)
wave_cahk, flux_cahk = local_normalize(spectrum, line_center=3950.0 * (1 + v_over_c), window=30, shoulder=8)
wave_na,   flux_na   = local_normalize(spectrum, line_center=na_ref,  window=20, shoulder=6)
wave_mg,   flux_mg   = local_normalize(spectrum, line_center=mg_ref,  window=20, shoulder=6)

# centroid check printout
print("\n--- Centroid Check (offsets should now be near 0) ---")
if wave_ha is not None:
    c_ha2 = centroid(wave_ha, flux_ha, ha_ref)
    if c_ha2: print(f"H-alpha:  ref={ha_ref:.3f} Å,  centroid={c_ha2:.3f} Å,  offset={c_ha2 - ha_ref:.3f} Å")
if wave_li is not None:
    c_li = centroid(wave_li, flux_li, li_ref)
    if c_li: print(f"Lithium:  ref={li_ref:.3f} Å,  centroid={c_li:.3f} Å,  offset={c_li - li_ref:.3f} Å")
if wave_na is not None:
    c_na = centroid(wave_na, flux_na, na_ref)
    if c_na: print(f"Na D1:    ref={na_ref:.3f} Å,  centroid={c_na:.3f} Å,  offset={c_na - na_ref:.3f} Å")
if wave_mg is not None:
    c_mg = centroid(wave_mg, flux_mg, mg_ref)
    if c_mg: print(f"Mg b:     ref={mg_ref:.3f} Å,  centroid={c_mg:.3f} Å,  offset={c_mg - mg_ref:.3f} Å")

# ==== 4-PANEL PLOT ====
figures, graphs = plt.subplots(2, 2, figsize=(10, 8))
plt.suptitle(f'\nLocally Normalized Key Spectral Features for {star}\n(RV = {velocity_km_s:.1f} km/s via {"Na D1" if ha_is_emission else "H-alpha"})', fontsize=14)
